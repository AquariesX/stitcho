datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  TAILOR
  CUSTOMER // Keeping it here just in case, but Customers now have their own table
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  COMPLETED
  CANCELLED
}

enum MeasurementType {
  STANDARD
  CUSTOM
}

enum MeasurementScale {
  INCH
  CM
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  PAID
  FAILED
}

model User {
  id          Int      @id @default(autoincrement())
  firebaseUid String   @unique @db.VarChar(128)
  name        String   @db.VarChar(100)
  email       String?  @db.VarChar(120)
  phoneNumber String?  @db.VarChar(20)
  role        Role
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  measurements Measurement[]
  shopProfile  ShopProfile?
  categories   Category[]
  products     Product[]
  fabrics      Fabric[]
  colors       Color[]
  styles       Style[]
  // orders removed from User, now in Customer

  @@map("users")
}

model ShopProfile {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  shopName          String   @db.VarChar(100)
  shopAddress       String   @db.Text
  city              String?  @db.VarChar(100)
  state             String?  @db.VarChar(100)
  postalCode        String?  @db.VarChar(20)
  country           String?  @default("Pakistan") @db.VarChar(100)
  landmark          String?  @db.VarChar(255)
  workingHours      String   @db.VarChar(100)
  specialization    String   @db.VarChar(100)
  yearsOfExperience Int
  shopLogoUrl       String?  @db.VarChar(500)
  description       String?  @db.Text
  priceRange        String?  @db.VarChar(50)
  currency          String   @default("PKR") @db.VarChar(10)
  phoneNumber       String?  @db.VarChar(20)
  whatsappNumber    String?  @db.VarChar(20)
  shopEmail         String?  @db.VarChar(120)
  website           String?  @db.VarChar(255)
  facebookUrl       String?  @db.VarChar(255)
  instagramUrl      String?  @db.VarChar(255)
  deliveryAvailable Boolean  @default(false)
  deliveryRadius    String?  @db.VarChar(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shop_profiles")
}

model Customer {
  id          Int      @id @default(autoincrement())
  firebaseUid String   @unique @db.VarChar(128)
  name        String   @db.VarChar(100)
  email       String?  @db.VarChar(120)
  phoneNumber String?  @db.VarChar(20)
  photoUrl    String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]
  // Measurements could be linked here too if needed, but for now Standard measurements are by Users(Admins)
  // If customers have custom measurements, we might need a relation or just rely on Order specific measurements

  @@map("customers")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(80)
  code      String   @unique @db.VarChar(20)
  imageUrl  String   @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int?

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  products Product[]
  fabrics  Fabric[]

  @@map("categories")
}

model Product {
  id         Int      @id @default(autoincrement())
  categoryId Int
  name       String   @db.VarChar(120)
  code       String   @unique @db.VarChar(30)
  imageUrl   String   @db.VarChar(500)
  basePrice  Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     Int?

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  fabrics  Fabric[]
  orders   Order[]

  @@index([categoryId])
  @@map("products")
}

model Fabric {
  id         Int      @id @default(autoincrement())
  categoryId Int
  name       String   @db.VarChar(100)
  imageUrl   String   @db.VarChar(500)
  price      Decimal  @db.Decimal(8, 2) // usually fabrics are cheaper than full product
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     Int?

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  category Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  products Product[]
  orders   Order[]

  @@index([categoryId])
  @@map("fabrics")
}

model Color {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(60)
  hexCode   String   @db.Char(7) // #RRGGBB format
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int?

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders Order[]

  @@map("colors")
}

model Style {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(80)
  imageUrl  String   @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int?

  user    User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  options StyleOption[]

  @@map("styles")
}

model StyleOption {
  id              Int      @id @default(autoincrement())
  styleId         Int
  name            String   @db.VarChar(100)
  imageUrl        String   @db.VarChar(500)
  additionalPrice Decimal  @default(0.00) @db.Decimal(8, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  style       Style        @relation(fields: [styleId], references: [id], onDelete: Cascade)
  orderStyles OrderStyle[]

  @@index([styleId])
  @@map("style_options")
}

model Measurement {
  id              Int              @id @default(autoincrement())
  label           String           @db.VarChar(50) // S, M, L, XL, Custom name...
  neck            Decimal          @db.Decimal(5, 2)
  chest           Decimal          @db.Decimal(5, 2)
  stomach         Decimal          @db.Decimal(5, 2)
  length          Decimal          @db.Decimal(5, 2) // usually called "shirt length" or "dress length"
  shoulder        Decimal          @db.Decimal(5, 2)
  sleeve          Decimal          @db.Decimal(5, 2)
  scale           MeasurementScale
  type            MeasurementType
  createdByUserId Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  createdBy User    @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  orders    Order[]

  @@index([createdByUserId])
  @@map("measurements")
}

model Order {
  id            Int         @id @default(autoincrement())
  customerId    Int
  productId     Int
  fabricId      Int
  colorId       Int
  measurementId Int
  totalPrice    Decimal     @db.Decimal(12, 2)
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  fabric      Fabric      @relation(fields: [fabricId], references: [id], onDelete: Restrict)
  color       Color       @relation(fields: [colorId], references: [id], onDelete: Restrict)
  measurement Measurement @relation(fields: [measurementId], references: [id], onDelete: Restrict)

  orderStyles OrderStyle[]
  payment     Payment?

  @@index([customerId])
  @@index([productId])
  @@index([fabricId])
  @@index([colorId])
  @@index([measurementId])
  @@map("orders")
}

model OrderStyle {
  id            Int      @id @default(autoincrement())
  orderId       Int
  styleOptionId Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  styleOption StyleOption @relation(fields: [styleOptionId], references: [id], onDelete: Cascade)

  @@unique([orderId, styleOptionId]) // prevent duplicate style options in same order
  @@index([orderId])
  @@index([styleOptionId])
  @@map("order_styles")
}

model Payment {
  id                    Int           @id @default(autoincrement())
  orderId               Int           @unique
  stripePaymentIntentId String        @db.VarChar(255)
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("PKR") @db.Char(3)
  status                PaymentStatus @default(REQUIRES_PAYMENT)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

enum NotificationType {
  TAILOR_SIGNUP
  CUSTOMER_SIGNUP
  PROFILE_UPDATE
  SHOP_UPDATE
  ORDER_STATUS
  INVENTORY_ALERT
  SYSTEM
}

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType
  title     String           @db.VarChar(200)
  message   String           @db.Text
  isRead    Boolean          @default(false)
  metadata  Json? // Store extra data like userId, orderId, etc.
  createdAt DateTime         @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}
