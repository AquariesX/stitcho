datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  TAILOR
  CUSTOMER // Kept for compatibility; Customers use their own table
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  CUTTING
  STITCHING
  READY
  DELIVERED
  COMPLETED
  CANCELLED
  CANCEL_REQUESTED
  REFUND_PENDING
  REFUNDED
}

enum MeasurementType {
  STANDARD
  CUSTOM
}

enum MeasurementScale {
  INCH
  CM
}

enum PaymentStatus {
  PENDING
  REQUIRES_PAYMENT
  PAID
  FAILED
  REFUNDED
  COD_PENDING
  COD_COLLECTED
}

enum NotificationType {
  TAILOR_SIGNUP
  CUSTOMER_SIGNUP
  PROFILE_UPDATE
  SHOP_UPDATE
  ORDER_STATUS
  INVENTORY_ALERT
  SYSTEM
}

enum ProductType {
  SHALWAR_KAMEEZ
  T_SHIRT
  PANTS
  FORMAL_SHIRT
}

enum Gender {
  MEN
}

enum PreviewView {
  FRONT
  BACK
}

enum StyleGroupType {
  COLLAR
  NECK
  SLEEVE
  CUFF
  POCKET
  PLACKET
  FIT
  SHALWAR_STYLE
  WAIST
  FRONT
  BOTTOM
}

enum AssetStorageType {
  LOCAL
  REMOTE
}

enum StyleType {
  COLLAR
  CUFF
  POCKET
  BUTTON
  OTHER
}

// ─────────────────────────────────────────────
// USER & SHOP
// ─────────────────────────────────────────────

model User {
  id          Int      @id @default(autoincrement())
  firebaseUid String   @unique @db.VarChar(128)
  name        String   @db.VarChar(100)
  email       String?  @db.VarChar(120)
  phoneNumber String?  @db.VarChar(20)
  role        Role
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  measurements Measurement[]
  shopProfile  ShopProfile?
  categories   Category[]
  products     Product[]
  fabrics      Fabric[]
  colors       Color[]
  styles       Style[]
  designs      Design[]

  // ── NEW: orders assigned to this tailor (role = TAILOR)
  tailoredOrders Order[] @relation("TailorOrders")

  @@map("users")
}

model ShopProfile {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  shopName          String   @db.VarChar(100)
  shopAddress       String   @db.Text
  city              String?  @db.VarChar(100)
  state             String?  @db.VarChar(100)
  postalCode        String?  @db.VarChar(20)
  country           String?  @default("Pakistan") @db.VarChar(100)
  landmark          String?  @db.VarChar(255)
  workingHours      String   @db.VarChar(100)
  specialization    String   @db.VarChar(100)
  yearsOfExperience Int
  shopLogoUrl       String?  @db.VarChar(500)
  description       String?  @db.Text
  priceRange        String?  @db.VarChar(50)
  currency          String   @default("PKR") @db.VarChar(10)
  phoneNumber       String?  @db.VarChar(20)
  whatsappNumber    String?  @db.VarChar(20)
  shopEmail         String?  @db.VarChar(120)
  website           String?  @db.VarChar(255)
  facebookUrl       String?  @db.VarChar(255)
  instagramUrl      String?  @db.VarChar(255)
  deliveryAvailable Boolean  @default(false)
  deliveryRadius    String?  @db.VarChar(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shop_profiles")
}

// ─────────────────────────────────────────────
// CUSTOMER & ADDRESS
// ─────────────────────────────────────────────

model Customer {
  id          Int      @id @default(autoincrement())
  firebaseUid String   @unique @db.VarChar(128)
  name        String   @db.VarChar(100)
  email       String?  @db.VarChar(120)
  phoneNumber String?  @db.VarChar(20)
  photoUrl    String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders    Order[]
  // ── NEW: saved delivery addresses for this customer
  addresses Address[]

  @@map("customers")
}

// ── NEW MODEL: Address
// Stores delivery / shipping addresses for customers.
// One customer can have multiple addresses (home, office, etc.).
model Address {
  id          Int      @id @default(autoincrement())
  customerId  Int
  fullName    String   @db.VarChar(100)
  phoneNumber String   @db.VarChar(20)
  address     String   @db.VarChar(255)
  city        String   @db.VarChar(100)
  postalCode  String   @db.VarChar(20)
  country     String   @default("Pakistan") @db.VarChar(100)
  isDefault   Boolean  @default(false) // mark one address as default
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[] // orders delivered to this address

  @@index([customerId])
  @@map("addresses")
}

// ─────────────────────────────────────────────
// CATALOG: CATEGORY, DESIGN, PRODUCT, FABRIC
// ─────────────────────────────────────────────

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(80)
  code      String   @db.VarChar(20)
  imageUrl  String   @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int?

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  products Product[]
  fabrics  Fabric[]
  designs  Design[]

  @@unique([userId, code])
  @@map("categories")
}

model Design {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  imageUrl    String
  basePrice   Float
  categoryId  Int
  userId      Int?
  createdAt   DateTime @default(now())

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@map("designs")
}

model Product {
  id                 Int              @id @default(autoincrement())
  categoryId         Int
  name               String           @db.VarChar(120)
  code               String           @unique @db.VarChar(30)
  imageUrl           String           @db.VarChar(500)
  thumbnailUrl       String?          @db.VarChar(500)
  modelImageUrl      String?          @db.VarChar(500)
  topOverlayUrl      String?          @db.VarChar(500)
  bottomOverlayUrl   String?          @db.VarChar(500)
  overlayKey         String?          @db.VarChar(100)
  previewEnabled     Boolean          @default(false)
  basePrice          Decimal          @db.Decimal(10, 2)
  description        String?          @db.Text
  productType        ProductType?
  gender             Gender           @default(MEN)
  previewType        String?          @db.VarChar(50)
  frontPreviewAsset  String?          @db.VarChar(500)
  backPreviewAsset   String?          @db.VarChar(500)
  previewStorageType AssetStorageType @default(LOCAL)
  estimatedDays      Int?
  measurementProfile String?          @db.VarChar(50)
  isFeatured         Boolean          @default(false)
  displayOrder       Int              @default(0)
  // ── NEW: mark product as available/unavailable for ordering
  isAvailable        Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  userId             Int?

  user             User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  category         Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  fabrics          Fabric[]
  supportedFabrics ProductFabric[]
  supportedColors  ProductColor[]
  supportedStyles  ProductStyle[]
  previewAssets    ProductPreviewAsset[]
  orders           Order[]

  @@index([categoryId])
  @@index([productType, isAvailable])
  @@index([displayOrder])
  @@map("products")
}

model Fabric {
  id                 Int              @id @default(autoincrement())
  categoryId         Int
  name               String           @db.VarChar(100)
  imageUrl           String           @db.VarChar(500)
  price              Decimal          @db.Decimal(8, 2)
  // ── NEW: inventory / stock tracking fields
  stockQuantity      Int              @default(0) // current stock in meters/units
  lowStockLimit      Int              @default(5) // alert threshold
  isAvailable        Boolean          @default(true) // hide from catalog when out of stock
  description        String?          @db.Text
  textureUrl         String?          @db.VarChar(500)
  textureStorageType AssetStorageType @default(REMOTE)
  priceAdjustment    Decimal          @default(0.00) @db.Decimal(8, 2)
  unit               String           @default("METER") @db.VarChar(20)
  isSeamlessTexture  Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  userId             Int?

  user              User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  category          Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  products          Product[]
  supportedProducts ProductFabric[]
  compatibleTypes   FabricCompatibility[]
  orders            Order[]

  @@index([categoryId])
  @@map("fabrics")
}

// ─────────────────────────────────────────────
// STYLES & COLORS
// ─────────────────────────────────────────────

model Color {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(60)
  hexCode      String   @db.Char(7) // #RRGGBB format
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       Int?
  isAvailable  Boolean  @default(true)
  displayOrder Int      @default(0)

  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  supportedProducts ProductColor[]
  orders            Order[]

  @@unique([userId, hexCode])
  @@index([isAvailable, displayOrder])
  @@map("colors")
}

model Style {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(80)
  imageUrl      String?         @db.VarChar(500)
  productType   ProductType?
  groupType     StyleGroupType?
  isRequired    Boolean         @default(false)
  allowMultiple Boolean         @default(false)
  displayOrder  Int             @default(0)
  isAvailable   Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  userId        Int?

  user    User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  options StyleOption[]

  @@index([productType, groupType, isAvailable])
  @@map("styles")
}

model StyleOption {
  id                Int              @id @default(autoincrement())
  styleId           Int
  name              String           @db.VarChar(100)
  imageUrl          String           @db.VarChar(500)
  additionalPrice   Decimal          @default(0.00) @db.Decimal(8, 2)
  overlayKey        String?          @db.VarChar(100)
  overlayImageUrl   String?          @db.VarChar(500)
  styleType         StyleType?
  zIndex            Int              @default(30)
  frontOverlayAsset String?          @db.VarChar(500)
  backOverlayAsset  String?          @db.VarChar(500)
  assetStorageType  AssetStorageType @default(LOCAL)
  isDefault         Boolean          @default(false)
  isAvailable       Boolean          @default(true)
  displayOrder      Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  style             Style          @relation(fields: [styleId], references: [id], onDelete: Cascade)
  orderStyles       OrderStyle[]
  supportedProducts ProductStyle[]

  @@index([styleId])
  @@index([isAvailable, displayOrder])
  @@map("style_options")
}

model ProductFabric {
  productId       Int
  fabricId        Int
  isDefault       Boolean  @default(false)
  priceAdjustment Decimal  @default(0.00) @db.Decimal(8, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  fabric  Fabric  @relation(fields: [fabricId], references: [id], onDelete: Cascade)

  @@id([productId, fabricId])
  @@index([fabricId])
  @@map("product_fabrics")
}

model FabricCompatibility {
  fabricId    Int
  productType ProductType
  createdAt   DateTime    @default(now())

  fabric Fabric @relation(fields: [fabricId], references: [id], onDelete: Cascade)

  @@id([fabricId, productType])
  @@index([productType])
  @@map("fabric_compatibilities")
}

model ProductColor {
  productId Int
  colorId   Int
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  color   Color   @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@id([productId, colorId])
  @@index([colorId])
  @@map("product_colors")
}

model ProductStyle {
  productId     Int
  styleOptionId Int
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  styleOption StyleOption @relation(fields: [styleOptionId], references: [id], onDelete: Cascade)

  @@id([productId, styleOptionId])
  @@index([styleOptionId])
  @@map("product_styles")
}

model ProductPreviewAsset {
  id          Int              @id @default(autoincrement())
  productId   Int
  view        PreviewView
  assetKey    String           @db.VarChar(100)
  assetUrl    String           @db.VarChar(500)
  storageType AssetStorageType @default(LOCAL)
  width       Int?
  height      Int?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, view, assetKey])
  @@index([productId])
  @@map("product_preview_assets")
}

// ─────────────────────────────────────────────
// MEASUREMENTS
// ─────────────────────────────────────────────

model Measurement {
  id              Int              @id @default(autoincrement())
  label           String           @db.VarChar(50) // S, M, L, XL, Custom name…
  // ── EXISTING shirt fields
  neck            Decimal?         @db.Decimal(5, 2)
  chest           Decimal?         @db.Decimal(5, 2)
  stomach         Decimal?         @db.Decimal(5, 2)
  length          Decimal?         @db.Decimal(5, 2) // shirt / dress length
  shoulder        Decimal?         @db.Decimal(5, 2)
  sleeve          Decimal?         @db.Decimal(5, 2)
  // ── NEW: pants / bottom wear fields
  waist           Decimal?         @db.Decimal(5, 2) // optional – not needed for shirts
  hip             Decimal?         @db.Decimal(5, 2)
  inseam          Decimal?         @db.Decimal(5, 2) // inside leg length
  thigh           Decimal?         @db.Decimal(5, 2)
  // ── NEW: coat / sherwani specific
  coatLength      Decimal?         @db.Decimal(5, 2)
  wrist           Decimal?         @db.Decimal(5, 2)
  productType     ProductType?
  profileName     String?          @db.VarChar(50)
  scale           MeasurementScale
  type            MeasurementType
  createdByUserId Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  createdBy User    @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  orders    Order[]

  @@index([createdByUserId])
  @@map("measurements")
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────

model Order {
  id                    Int         @id @default(autoincrement())
  customerId            Int
  productId             Int
  fabricId              Int
  colorId               Int
  measurementId         Int
  tailorId              Int?
  addressId             Int?
  totalPrice            Decimal     @db.Decimal(12, 2)
  status                OrderStatus @default(PENDING)
  notes                 String?     @db.Text
  // ── Cancellation & Refund
  cancellationReason    String?     @db.VarChar(500)
  // ── Smart features
  estimatedDeliveryDate DateTime?
  // ── Image reference from customer
  referenceImageUrl     String?     @db.VarChar(500)
  // ── Payment method: STRIPE or COD
  paymentMethod         String      @default("STRIPE") @db.VarChar(20)
  previewType           String?     @db.VarChar(50)
  previewFrontUrl       String?     @db.VarChar(500)
  previewBackUrl        String?     @db.VarChar(500)
  customizationSnapshot Json?
  previewGeneratedAt    DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  fabric      Fabric      @relation(fields: [fabricId], references: [id], onDelete: Restrict)
  color       Color       @relation(fields: [colorId], references: [id], onDelete: Restrict)
  measurement Measurement @relation(fields: [measurementId], references: [id], onDelete: Restrict)
  tailor      User?       @relation("TailorOrders", fields: [tailorId], references: [id], onDelete: SetNull)
  address     Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)

  orderStyles   OrderStyle[]
  payment       Payment?
  statusHistory OrderStatusHistory[]

  @@index([customerId])
  @@index([productId])
  @@index([fabricId])
  @@index([colorId])
  @@index([measurementId])
  @@index([tailorId])
  @@index([addressId])
  @@map("orders")
}

// ── NEW MODEL: OrderStatusHistory
// Tracks every status transition for an order.
// Enables a full order lifecycle timeline in the dashboard and mobile app.
model OrderStatusHistory {
  id        Int         @id @default(autoincrement())
  orderId   Int
  status    OrderStatus
  note      String?     @db.VarChar(500) // optional comment (e.g. "Fabric cut complete")
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("order_status_history")
}

model OrderStyle {
  id            Int      @id @default(autoincrement())
  orderId       Int
  styleOptionId Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  styleOption StyleOption @relation(fields: [styleOptionId], references: [id], onDelete: Cascade)

  @@unique([orderId, styleOptionId]) // prevent duplicate style options in same order
  @@index([orderId])
  @@index([styleOptionId])
  @@map("order_styles")
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id                    Int           @id @default(autoincrement())
  orderId               Int           @unique
  stripePaymentIntentId String        @db.VarChar(255)
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("PKR") @db.Char(3)
  status                PaymentStatus @default(REQUIRES_PAYMENT)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType
  title     String           @db.VarChar(200)
  message   String           @db.Text
  isRead    Boolean          @default(false)
  metadata  Json? // Store extra data like userId, orderId, etc.
  createdAt DateTime         @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────

// Tracks all important admin/tailor actions for accountability.
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int? // The user who performed the action (nullable for system actions)
  userRole  String?  @db.VarChar(20) // ADMIN | TAILOR
  action    String   @db.VarChar(100) // e.g. "UPDATE_ORDER_STATUS", "DELETE_FABRIC"
  module    String   @db.VarChar(50) // e.g. "Orders", "Fabrics", "Payments"
  entityId  Int? // ID of the record affected
  oldValue  Json? // Snapshot before change
  newValue  Json? // Snapshot after change
  ipAddress String?  @db.VarChar(50)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}
