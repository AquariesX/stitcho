datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  TAILOR
  CUSTOMER // Kept for compatibility; Customers use their own table
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  CUTTING
  STITCHING
  READY
  DELIVERED
  COMPLETED
  CANCELLED
}

enum MeasurementType {
  STANDARD
  CUSTOM
}

enum MeasurementScale {
  INCH
  CM
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  PAID
  FAILED
}

enum NotificationType {
  TAILOR_SIGNUP
  CUSTOMER_SIGNUP
  PROFILE_UPDATE
  SHOP_UPDATE
  ORDER_STATUS
  INVENTORY_ALERT
  SYSTEM
}

// ─────────────────────────────────────────────
// USER & SHOP
// ─────────────────────────────────────────────

model User {
  id          Int      @id @default(autoincrement())
  firebaseUid String   @unique @db.VarChar(128)
  name        String   @db.VarChar(100)
  email       String?  @db.VarChar(120)
  phoneNumber String?  @db.VarChar(20)
  role        Role
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  measurements Measurement[]
  shopProfile  ShopProfile?
  categories   Category[]
  products     Product[]
  fabrics      Fabric[]
  colors       Color[]
  styles       Style[]
  designs      Design[]

  // ── NEW: orders assigned to this tailor (role = TAILOR)
  tailoredOrders Order[] @relation("TailorOrders")

  @@map("users")
}

model ShopProfile {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  shopName          String   @db.VarChar(100)
  shopAddress       String   @db.Text
  city              String?  @db.VarChar(100)
  state             String?  @db.VarChar(100)
  postalCode        String?  @db.VarChar(20)
  country           String?  @default("Pakistan") @db.VarChar(100)
  landmark          String?  @db.VarChar(255)
  workingHours      String   @db.VarChar(100)
  specialization    String   @db.VarChar(100)
  yearsOfExperience Int
  shopLogoUrl       String?  @db.VarChar(500)
  description       String?  @db.Text
  priceRange        String?  @db.VarChar(50)
  currency          String   @default("PKR") @db.VarChar(10)
  phoneNumber       String?  @db.VarChar(20)
  whatsappNumber    String?  @db.VarChar(20)
  shopEmail         String?  @db.VarChar(120)
  website           String?  @db.VarChar(255)
  facebookUrl       String?  @db.VarChar(255)
  instagramUrl      String?  @db.VarChar(255)
  deliveryAvailable Boolean  @default(false)
  deliveryRadius    String?  @db.VarChar(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("shop_profiles")
}

// ─────────────────────────────────────────────
// CUSTOMER & ADDRESS
// ─────────────────────────────────────────────

model Customer {
  id          Int      @id @default(autoincrement())
  firebaseUid String   @unique @db.VarChar(128)
  name        String   @db.VarChar(100)
  email       String?  @db.VarChar(120)
  phoneNumber String?  @db.VarChar(20)
  photoUrl    String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders    Order[]
  // ── NEW: saved delivery addresses for this customer
  addresses Address[]

  @@map("customers")
}

// ── NEW MODEL: Address
// Stores delivery / shipping addresses for customers.
// One customer can have multiple addresses (home, office, etc.).
model Address {
  id          Int      @id @default(autoincrement())
  customerId  Int
  fullName    String   @db.VarChar(100)
  phoneNumber String   @db.VarChar(20)
  address     String   @db.VarChar(255)
  city        String   @db.VarChar(100)
  postalCode  String   @db.VarChar(20)
  country     String   @default("Pakistan") @db.VarChar(100)
  isDefault   Boolean  @default(false) // mark one address as default
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]  // orders delivered to this address

  @@index([customerId])
  @@map("addresses")
}

// ─────────────────────────────────────────────
// CATALOG: CATEGORY, DESIGN, PRODUCT, FABRIC
// ─────────────────────────────────────────────

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(80)
  code      String   @unique @db.VarChar(20)
  imageUrl  String   @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int?

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  products Product[]
  fabrics  Fabric[]
  designs  Design[]

  @@map("categories")
}

model Design {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  imageUrl    String
  basePrice   Float
  categoryId  Int
  userId      Int?
  createdAt   DateTime @default(now())

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([categoryId])
  @@map("designs")
}

model Product {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  name        String   @db.VarChar(120)
  code        String   @unique @db.VarChar(30)
  imageUrl    String   @db.VarChar(500)
  basePrice   Decimal  @db.Decimal(10, 2)
  // ── NEW: mark product as available/unavailable for ordering
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int?

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  fabrics  Fabric[]
  orders   Order[]

  @@index([categoryId])
  @@map("products")
}

model Fabric {
  id           Int      @id @default(autoincrement())
  categoryId   Int
  name         String   @db.VarChar(100)
  imageUrl     String   @db.VarChar(500)
  price        Decimal  @db.Decimal(8, 2)
  // ── NEW: inventory / stock tracking fields
  stockQuantity Int     @default(0)   // current stock in meters/units
  lowStockLimit Int     @default(5)   // alert threshold
  isAvailable   Boolean @default(true) // hide from catalog when out of stock
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       Int?

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  products Product[]
  orders   Order[]

  @@index([categoryId])
  @@map("fabrics")
}

// ─────────────────────────────────────────────
// STYLES & COLORS
// ─────────────────────────────────────────────

model Color {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(60)
  hexCode   String   @db.Char(7) // #RRGGBB format
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int?

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders Order[]

  @@map("colors")
}

model Style {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(80)
  imageUrl  String   @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int?

  user    User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  options StyleOption[]

  @@map("styles")
}

model StyleOption {
  id              Int      @id @default(autoincrement())
  styleId         Int
  name            String   @db.VarChar(100)
  imageUrl        String   @db.VarChar(500)
  additionalPrice Decimal  @default(0.00) @db.Decimal(8, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  style       Style        @relation(fields: [styleId], references: [id], onDelete: Cascade)
  orderStyles OrderStyle[]

  @@index([styleId])
  @@map("style_options")
}

// ─────────────────────────────────────────────
// MEASUREMENTS
// ─────────────────────────────────────────────

model Measurement {
  id              Int              @id @default(autoincrement())
  label           String           @db.VarChar(50) // S, M, L, XL, Custom name…
  // ── EXISTING shirt fields
  neck            Decimal          @db.Decimal(5, 2)
  chest           Decimal          @db.Decimal(5, 2)
  stomach         Decimal          @db.Decimal(5, 2)
  length          Decimal          @db.Decimal(5, 2) // shirt / dress length
  shoulder        Decimal          @db.Decimal(5, 2)
  sleeve          Decimal          @db.Decimal(5, 2)
  // ── NEW: pants / bottom wear fields
  waist           Decimal?         @db.Decimal(5, 2) // optional – not needed for shirts
  hip             Decimal?         @db.Decimal(5, 2)
  inseam          Decimal?         @db.Decimal(5, 2) // inside leg length
  thigh           Decimal?         @db.Decimal(5, 2)
  // ── NEW: coat / sherwani specific
  coatLength      Decimal?         @db.Decimal(5, 2)
  scale           MeasurementScale
  type            MeasurementType
  createdByUserId Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  createdBy User    @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  orders    Order[]

  @@index([createdByUserId])
  @@map("measurements")
}

// ─────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────

model Order {
  id            Int         @id @default(autoincrement())
  customerId    Int
  productId     Int
  fabricId      Int
  colorId       Int
  measurementId Int
  // ── NEW: tailor assigned to fulfil this order (User with role = TAILOR)
  tailorId      Int?
  // ── NEW: delivery address chosen at checkout
  addressId     Int?
  totalPrice    Decimal     @db.Decimal(12, 2)
  status        OrderStatus @default(PENDING)
  notes         String?     @db.Text // optional order notes from customer
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  fabric      Fabric      @relation(fields: [fabricId], references: [id], onDelete: Restrict)
  color       Color       @relation(fields: [colorId], references: [id], onDelete: Restrict)
  measurement Measurement @relation(fields: [measurementId], references: [id], onDelete: Restrict)
  // ── NEW relations
  tailor      User?       @relation("TailorOrders", fields: [tailorId], references: [id], onDelete: SetNull)
  address     Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)

  orderStyles  OrderStyle[]
  payment      Payment?
  // ── NEW: full status change history
  statusHistory OrderStatusHistory[]

  @@index([customerId])
  @@index([productId])
  @@index([fabricId])
  @@index([colorId])
  @@index([measurementId])
  @@index([tailorId])   // NEW index
  @@index([addressId])  // NEW index
  @@map("orders")
}

// ── NEW MODEL: OrderStatusHistory
// Tracks every status transition for an order.
// Enables a full order lifecycle timeline in the dashboard and mobile app.
model OrderStatusHistory {
  id        Int         @id @default(autoincrement())
  orderId   Int
  status    OrderStatus
  note      String?     @db.VarChar(500) // optional comment (e.g. "Fabric cut complete")
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("order_status_history")
}

model OrderStyle {
  id            Int      @id @default(autoincrement())
  orderId       Int
  styleOptionId Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  styleOption StyleOption @relation(fields: [styleOptionId], references: [id], onDelete: Cascade)

  @@unique([orderId, styleOptionId]) // prevent duplicate style options in same order
  @@index([orderId])
  @@index([styleOptionId])
  @@map("order_styles")
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id                    Int           @id @default(autoincrement())
  orderId               Int           @unique
  stripePaymentIntentId String        @db.VarChar(255)
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("PKR") @db.Char(3)
  status                PaymentStatus @default(REQUIRES_PAYMENT)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType
  title     String           @db.VarChar(200)
  message   String           @db.Text
  isRead    Boolean          @default(false)
  metadata  Json? // Store extra data like userId, orderId, etc.
  createdAt DateTime         @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}
